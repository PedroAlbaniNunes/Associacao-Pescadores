{
  "name": "associacao-pescadores-backend",
  "version": "1.0.0",
  "description": "API REST do Sistema de Associação de Pescadores",
  "type": "module",
  "main": "dist/servidor.js",
  "scripts": {
    "dev": "tsx watch src/servidor.ts",
    "build": "tsc",
    "start": "node dist/servidor.js",
    "prisma:gerar": "prisma generate",
    "prisma:sincronizar": "sqlite3 prisma/dev.db < prisma/init.sql",
    "prisma:migrar": "prisma migrate dev",
    "prisma:semear": "node --import tsx prisma/seed.ts",
    "prisma:resetar": "rm -f prisma/dev.db && npm run preparar",
    "prisma:studio": "prisma studio",
    "preparar": "prisma generate && npm run prisma:sincronizar && npm run prisma:semear"
  },
  "dependencies": {
    "@fastify/cors": "9.0.1",
    "@fastify/jwt": "8.0.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "4.28.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.16.10",
    "prisma": "^5.22.0",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
