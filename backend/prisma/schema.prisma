generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USUÁRIOS DO PAINEL ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String
  papel     String   @default("ADMIN")
  criadoEm  DateTime @default(now())

  logsAuditoria LogAuditoria[]

  @@map("usuarios")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSOCIADOS (PESCADORES)
// ─────────────────────────────────────────────────────────────────────────────

model Associado {
  id              String           @id @default(uuid())
  nome            String
  cpf             String           @unique
  email           String           @unique
  telefone        String
  embarcacao      String?
  numeroCarteira  String           @unique
  status          String           @default("ativo")
  dataCadastro    DateTime         @default(now())
  observacoes     String?
  atualizadoEm    DateTime         @updatedAt

  lojas           Loja[]
  permissoes      Permissao[]
  presencas       PresencaReuniao[]
  mensalidades    Mensalidade[]
  historicoStatus HistoricoStatusAssociado[]
  vendas          Venda[]

  @@map("associados")
}

model HistoricoStatusAssociado {
  id             String          @id @default(uuid())
  associadoId    String
  statusAnterior String
  statusNovo     String
  motivo         String?
  alteradoEm     DateTime        @default(now())
  alteradoPor    String?

  associado Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  @@map("historico_status_associado")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOJAS
// ─────────────────────────────────────────────────────────────────────────────

model Loja {
  id              String     @id @default(uuid())
  associadoId     String
  nomeLoja        String
  descricao       String
  status          String   @default("pendente")
  dataSolicitacao DateTime   @default(now())
  dataAprovacao   DateTime?
  motivoRejeicao  String?
  atualizadoEm    DateTime   @updatedAt

  associado Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)
  produtos  Produto[]
  vendas    Venda[]

  @@map("lojas")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUTOS DAS LOJAS
// ─────────────────────────────────────────────────────────────────────────────

model Produto {
  id           String    @id @default(uuid())
  lojaId       String
  nome         String
  descricao    String?
  preco        Float
  estoque      Int       @default(0)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  loja       Loja        @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  itensVenda ItemVenda[]

  @@map("produtos")
}

// ─────────────────────────────────────────────────────────────────────────────
// VENDAS
// ─────────────────────────────────────────────────────────────────────────────

model Venda {
  id           String   @id @default(uuid())
  lojaId       String
  associadoId  String
  total        Float
  status       String   @default("concluida")
  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  loja       Loja        @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  associado  Associado   @relation(fields: [associadoId], references: [id], onDelete: Cascade)
  itens      ItemVenda[]
  transporte Transporte?

  @@map("vendas")
}

model ItemVenda {
  id            String @id @default(uuid())
  vendaId       String
  produtoId     String
  quantidade    Int
  precoUnitario Float
  subtotal      Float

  venda   Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  @@map("itens_venda")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSPORTES
// ─────────────────────────────────────────────────────────────────────────────

model Transporte {
  id             String    @id @default(uuid())
  vendaId        String    @unique
  transportadora String?
  destino        String
  status         String    @default("pendente")
  dataEnvio      DateTime?
  dataEntrega    DateTime?
  rastreamento   String?
  observacoes    String?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  venda Venda @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@map("transportes")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERMISSÕES DE PESCA / VENDA
// ─────────────────────────────────────────────────────────────────────────────

model Permissao {
  id             String    @id @default(uuid())
  associadoId    String
  tipoPermissao  String
  ativa          Boolean   @default(true)
  dataInicio     DateTime
  dataFim        DateTime?
  quota          Int?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  associado Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  @@map("permissoes")
}

// ─────────────────────────────────────────────────────────────────────────────
// REUNIÕES E PRESENÇAS
// ─────────────────────────────────────────────────────────────────────────────

model Reuniao {
  id          String         @id @default(uuid())
  titulo      String
  descricao   String
  data        DateTime
  horario     String
  local       String
  status      String         @default("agendada")
  pautaJson   String         @default("[]")
  ata         String?
  criadoEm    DateTime       @default(now())
  atualizadoEm DateTime      @updatedAt

  presencas PresencaReuniao[]

  @@map("reunioes")
}

model PresencaReuniao {
  id          String  @id @default(uuid())
  reuniaoId   String
  associadoId String
  presente    Boolean @default(false)

  reuniao   Reuniao   @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  associado Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  @@unique([reuniaoId, associadoId])
  @@map("presencas_reuniao")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENSALIDADES
// ─────────────────────────────────────────────────────────────────────────────

model Mensalidade {
  id             String             @id @default(uuid())
  associadoId    String
  competencia    String
  valor          Float
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String            @default("pendente")
  criadoEm       DateTime           @default(now())
  atualizadoEm   DateTime           @updatedAt

  associado Associado @relation(fields: [associadoId], references: [id], onDelete: Cascade)

  @@unique([associadoId, competencia])
  @@map("mensalidades")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDITORIA
// ─────────────────────────────────────────────────────────────────────────────

model LogAuditoria {
  id        String   @id @default(uuid())
  usuarioId String?
  acao      String
  entidade  String
  entidadeId String?
  detalhes  String?
  criadoEm  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("logs_auditoria")
}
